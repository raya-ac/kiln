# Consistent whitespace across editors. See https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Shell scripts: 2 spaces is idiomatic.
[*.sh]
indent_size = 2

# YAML requires 2-space indent to avoid parser grief.
[*.{yml,yaml}]
indent_size = 2

# Markdown — keep trailing whitespace (meaningful in some flavours for line breaks).
[*.md]
trim_trailing_whitespace = false

# Makefile tabs are load-bearing.
[{Makefile,makefile,*.mk}]
indent_style = tab
